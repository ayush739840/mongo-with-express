<!DOCTYPE html>
<html lang="en">
<head>
    
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Whatsapp</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>All chats</h1>
    <% for(let chat of chats ){ %>
        <div class="chat">
            <p>From :<%= chat.from%></p>
            
            <div class="msg"><p><%=chat.message%></p>
                
            <form method="get" action="/chats/<%=chat._id%>/edit">
                     <button>edit</button>
                </form>
                <br>
                <form method="post" action="/chats/<%=chat._id%>?_method=DELETE">
                     <button>delete</button>
                </form>
                <form action="/chats/<%=chat._id%>" method="get">
                    <button>Show</button>
                </form>

            </div>
            <p>Received By:<i> <%=chat.to%></i></p>
            <p><%= chat.created_at.toString().split(" ")[4] %></p>
            <p><%= chat.created_at.toString().split(" ").slice(0,4).join(" ") %></p>
            <hr>
        </div>
        <br><br>
    <% } %>
    

    <form  method="get" action="/chats/new">
        <button> new chat</button>
    </form>
</body>
</html>